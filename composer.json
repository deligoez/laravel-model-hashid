{
    "name": "deligoez/laravel-model-hashid",
    "description": "Generate, Save, and Route Stripe/Youtube-like Hash IDs for Laravel Eloquent Models",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "deligoez",
        "laravel",
        "laravel-package",
        "laravel-model-hashid",
        "hashids"
    ],
    "authors": [
        {
            "name": "Yunus Emre Deligöz",
            "email": "ye@deligoz.me",
            "homepage": "https://www.deligoz.me",
            "role": "Developer"
        }
    ],
    "homepage": "https://github.com/deligoez/laravel-model-hashid",
    "support": {
        "issues": "https://github.com/deligoez/laravel-model-hashid/issues",
        "source": "https://github.com/deligoez/laravel-model-hashid"
    },
    "require": {
        "php": "^8.3",
        "ext-mbstring": "*",
        "hashids/hashids": "^4.1|^5.0",
        "illuminate/contracts": "^11.0|^12.0"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.1",
        "laravel/pint": "^1.0",
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "pestphp/pest-plugin-type-coverage": "^4.0",
        "phpstan/extension-installer": "^1.2",
        "rector/rector": "^2.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Deligoez\\LaravelModelHashId\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Deligoez\\LaravelModelHashId\\Tests\\": "tests/",
            "Deligoez\\LaravelModelHashId\\Tests\\Database\\Factories\\": "tests/database/factories/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        },
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Deligoez\\LaravelModelHashId\\LaravelModelHashIdServiceProvider"
            ]
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "rector": "rector",
        "pint": "pint --config=pint.json",
        "test:rector": "rector --dry-run",
        "test:pint": "pint --config=pint.json --test",
        "test:phpstan": "phpstan analyse --configuration=phpstan.neon.dist --ansi",
        "test:unit": "pest --colors=always --order-by=random",
        "test:types": "pest --type-coverage --colors=always",
        "test:coverage": "pest --coverage --colors=always --min=80",
        "test:profile": "pest --profile --colors=always --order-by=random",
        "test": ["@test:rector", "@test:pint", "@test:phpstan", "@test:unit"]
    }
}
